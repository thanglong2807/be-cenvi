            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mau HD Dich Vu Ke Toan v1\",\n  \"contract_type_id\": 1,\n  \"content\": \"HOP DONG DICH VU KE TOAN\\n\\nBen A: {{ten_cong_ty}}\\nMa So Thue: {{ma_so_thue}}\\n\\nThoi han: {{duration_months}} thang\\nSo tien: {{payment_amount}} VND\",\n  \"fields\": [\n    {\n      \"field_name\": \"duration_months\",\n      \"field_label\": \"Thoi gian hop dong (thang)\",\n      \"field_type\": \"number\",\n      \"source\": \"custom\",\n      \"is_required\": true,\n      \"display_order\": 0\n    },\n    {\n      \"field_name\": \"payment_amount\",\n      \"field_label\": \"So tien thanh toan\",\n      \"field_type\": \"currency\",\n      \"source\": \"custom\",\n      \"is_required\": true,\n      \"display_order\": 1\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Update Template (Create New Version)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
